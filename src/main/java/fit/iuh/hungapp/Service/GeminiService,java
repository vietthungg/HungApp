package fit.iuh.hungapp.Service;

import com.google.common.collect.ImmutableList;
import com.google.genai.Client;
import com.google.genai.types.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;

@Service
public class GeminiService {

    @Value("${gemini.api.key}")
    private String apiKey;

    private final String MODEL_NAME = "gemini-3-flash-preview";

    /**
     * Hàm gọi Gemini để tư vấn kinh doanh Bánh Canh
     * @param userInput Câu hỏi từ khách hàng/người dùng
     * @return Câu trả lời dạng văn bản từ AI
     */
    public String askAI(String userInput) {
        // 1. Khởi tạo Client với API Key
        Client client = Client.builder().apiKey(apiKey).build();

        // 2. Thiết lập công cụ (Google Search)
        List<Tool> tools = new ArrayList<>();
        tools.add(Tool.builder()
                .googleSearch(GoogleSearch.builder())
                .build());

        // 3. Chuẩn bị nội dung câu hỏi từ người dùng
        List<Content> contents = ImmutableList.of(
            Content.builder()
                .role("user")
                .parts(ImmutableList.of(Part.fromText(userInput)))
                .build()
        );

        // 4. Cấu hình Prompt "Chuyên gia Bánh Canh" (System Instruction)
        String systemPrompt = "Vai trò: Bạn là một chuyên gia tư vấn kinh doanh F&B với hơn 15 năm kinh nghiệm quản lý các chuỗi cửa hàng đặc sản tại Việt Nam, đặc biệt am hiểu về mô hình quán Bánh Canh.\n" +
                "\n" +
                "Nhiệm vụ của bạn:\n" +
                "Quản lý Vận hành: Tư vấn cách chuẩn bị nguyên liệu (SOP), cách bảo quản sợi bánh canh và nước dùng để giữ vị tươi ngon suốt cả ngày.\n" +
                "Phân tích Tài chính: Hỗ trợ tính toán giá vốn (Food Cost), định giá bán và quản lý hao hụt nguyên liệu (như tôm, thịt, xương, bột).\n" +
                "Chiến lược Marketing: Đề xuất các chương trình khuyến mãi, cách thiết kế hình ảnh/biển hiệu thu hút (dựa trên kinh nghiệm từ thương hiệu Nhà RY) và cách chăm sóc khách hàng.\n" +
                "Giải quyết vấn đề: Đưa ra giải pháp cho các tình huống phát sinh như: quán vắng khách, xử lý phản hồi tiêu cực, hoặc tối ưu hóa quy trình giao hàng qua app.\n" +
                "Kiến thức chuyên sâu: Hiểu rõ sự khác biệt giữa các loại bánh canh (Bánh canh bột lọc, bột gạo, bánh canh ghẹ, cua, cá lóc...).\n" +
                "Am hiểu khẩu vị vùng miền để tư vấn điều chỉnh gia vị phù hợp.\n" +
                "Quy tắc phản hồi: Trả lời bằng tiếng Việt, giọng văn gần gũi nhưng chuyên nghiệp của một người chủ có tâm. Sử dụng bảng biểu khi cần. Luôn kết thúc bằng một lời khuyên về vệ sinh an toàn thực phẩm.";

        GenerateContentConfig config = GenerateContentConfig.builder()
                .thinkingConfig(ThinkingConfig.builder().thinkingLevel("HIGH").build())
                .tools(tools)
                .systemInstruction(Content.fromParts(Part.fromText(systemPrompt)))
                .build();

        // 5. Gọi AI và xử lý kết quả trả về (Dạng chuỗi văn bản gộp lại)
        StringBuilder fullResponse = new StringBuilder();
        try (var responseStream = client.models.generateContentStream(MODEL_NAME, contents, config)) {
            for (GenerateContentResponse res : responseStream) {
                res.candidates().ifPresent(candidates -> {
                    candidates.get(0).content().ifPresent(content -> {
                        content.parts().ifPresent(parts -> {
                            for (Part part : parts) {
                                fullResponse.append(part.text());
                            }
                        });
                    });
                });
            }
        } catch (Exception e) {
            return "Lỗi hệ thống khi gọi AI: " + e.getMessage();
        }

        return fullResponse.toString();
    }
}